# 开发环境配置
# Vite 环境变量必须以 VITE_ 开头才能在前端访问

# API 基础路径
VITE_API_BASE_URL=/api

# API 超时时间（毫秒）
VITE_API_TIMEOUT=60000

# 应用标题
VITE_APP_TITLE=AI选题Agent - 开发环境

# 应用版本
VITE_APP_VERSION=1.0.0

# 是否启用 Mock 数据
VITE_ENABLE_MOCK=false

# 是否启用请求日志
VITE_ENABLE_REQUEST_LOG=true

# 后端服务端口（仅后端使用）
PORT=3100

# 通义千问API密钥（仅后端使用）
DASHSCOPE_API_KEY=
