# 环境变量配置示例

# ⚠️ 重要说明：
# 1. 复制此文件为 .env.development.local 用于本地开发
# 2. .env.*.local 文件不会被提交到 Git
# 3. 本地配置会覆盖 .env.development 中的配置

# ===========================================
# 前端环境变量（必须以 VITE_ 开头）
# ===========================================

# API 基础路径
# 开发环境：使用代理到本地后端
VITE_API_BASE_URL=/api

# 如果后端在不同端口或域名：
# VITE_API_BASE_URL=http://localhost:3100/api
# VITE_API_BASE_URL=http://192.168.1.100:3100/api

# API 超时时间（毫秒）
VITE_API_TIMEOUT=60000

# 应用标题
VITE_APP_TITLE=AI选题Agent - 本地开发

# 应用版本
VITE_APP_VERSION=1.0.0-dev

# 是否启用 Mock 数据（开发时可启用）
VITE_ENABLE_MOCK=false

# 是否启用请求日志
VITE_ENABLE_REQUEST_LOG=true

# ===========================================
# 后端环境变量（不需要 VITE_ 前缀）
# ===========================================

# 后端服务端口
PORT=3100

# 通义千问 API 密钥（替换为你的实际密钥）
DASHSCOPE_API_KEY=your-api-key-here

# ===========================================
# 使用说明
# ===========================================

# 1. 创建本地配置文件：
#    cp .env.example .env.development.local

# 2. 修改 DASHSCOPE_API_KEY 为你的实际密钥

# 3. 如需修改 API 地址，调整 VITE_API_BASE_URL

# 4. 重启开发服务器：
#    bun run dev

# 5. 打开浏览器控制台，查看环境配置输出
